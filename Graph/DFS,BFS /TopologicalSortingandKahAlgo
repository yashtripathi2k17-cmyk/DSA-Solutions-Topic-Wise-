9. Code Template
// Step 1
vector<int> indegree(V,0);

// Step 2
for(int i=0;i<V;i++)
    for(auto it:adj[i])
        indegree[it]++;

// Step 3
queue<int> q;

for(int i=0;i<V;i++)
    if(indegree[i]==0)
        q.push(i);

// Step 4
vector<int> ans;

while(!q.empty()){

    int node=q.front();
    q.pop();

    ans.push_back(node);

    for(auto it:adj[node]){

        indegree[it]--;

        if(indegree[it]==0)
            q.push(it);
    }
}

return ans;
