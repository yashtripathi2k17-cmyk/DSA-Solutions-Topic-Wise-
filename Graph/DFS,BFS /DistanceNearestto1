8. Complete Code (Easy Version)
class Solution {
public:

    vector<vector<int>> nearest(vector<vector<int>>& grid) {

        int n = grid.size();
        int m = grid[0].size();

        vector<vector<int>> dist(n, vector<int>(m, -1));

        queue<pair<int,int>> q;

        // Push all 1's into queue
        for(int i = 0; i < n; i++) {
            for(int j = 0; j < m; j++) {

                if(grid[i][j] == 1) {
                    dist[i][j] = 0;
                    q.push({i, j});
                }

            }
        }

        int dr[] = {-1, 1, 0, 0};
        int dc[] = {0, 0, -1, 1};

        while(!q.empty()) {

            auto node = q.front();
            q.pop();

            int r = node.first;
            int c = node.second;

            for(int k = 0; k < 4; k++) {

                int nr = r + dr[k];
                int nc = c + dc[k];

                if(nr >= 0 && nr < n &&
                   nc >= 0 && nc < m &&
                   dist[nr][nc] == -1) {

                    dist[nr][nc] = dist[r][c] + 1;
                    q.push({nr, nc});
                }
            }
        }

        return dist;
    }
};
