class MyStack {
    queue<int>q;
public:
    MyStack() {
        
    }
    void push(int x) {
        int n=q.size();
        q.push(x);
        for(int i=0;i<n;i++){
            q.push(q.front());
            q.pop();
        }
    }
    
    int pop() {
        if(q.empty()){
            return -1;
        }
        int val=q.front();
        q.pop();
        return val;
    }
    
    int top() {
        if(q.empty()){
            return -1;
        }
        return q.front();
    }
    
    bool empty() {
        return q.empty();
    }
