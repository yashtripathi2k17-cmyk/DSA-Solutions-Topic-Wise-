class Solution {
public:
    void moveZeroes(vector<int>& nums) {

        int j = 0;

        for (int i = 0; i < nums.size(); i++) {

            if (nums[i] != 0) {
                swap(nums[i], nums[j]);
                j++;
            }
        }
    }
};
"I use two pointers. The fast pointer scans every element, while the slow pointer tracks the position 
where the next non-zero element should be placed. Every time I find a non-zero value, I move it to the front 
(either by copying or swapping) and increment the slow pointer. After processing all elements,
all non-zero values are at the beginning in their original order, and the remaining positions become zeros."
