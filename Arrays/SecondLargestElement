class Solution {
  public:
    int getSecondLargest(vector<int> &arr) {
        // code here
        int n=arr.size();
        int max=-1;
        int smax=-1;
        for(int i=0;i<n;i++){
            if(arr[i]>max){
                smax=max;
                max=arr[i];
            }
            else if(max>arr[i]&&arr[i]>smax){
                smax=arr[i];
            }
        }
        return smax;
    }
};
