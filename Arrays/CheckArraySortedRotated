A sorted array has 0 decreasing points. A sorted-and-rotated array has exactly 1
decreasing point. If there are more than 1 decreasing points, it cannot be obtained by rotating a sorted array.
class Solution {
public:
    bool check(vector<int>& nums) {

        int n = nums.size();
        int breaks = 0;

        for (int i = 1; i < n; i++) {
            if (nums[i] < nums[i - 1])
                breaks++;
        }

        if (nums[0] < nums[n - 1])
            breaks++;

        return breaks <= 1;
    }
};
