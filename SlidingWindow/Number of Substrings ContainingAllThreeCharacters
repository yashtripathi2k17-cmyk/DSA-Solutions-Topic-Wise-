Number of Substrings Containing All Three Characters
1-Brute force
class Solution {
public:
    int numberOfSubstrings(string s) {

        int n = s.length();
        int count = 0;

        for (int i = 0; i < n; i++) {

            vector<int> freq(3, 0);

            for (int j = i; j < n; j++) {

                freq[s[j] - 'a']++;

                if (freq[0] > 0 && freq[1] > 0 && freq[2] > 0) {
                    count++;
                }
            }
        }

        return count;
    }
};
2----Optimised code

class Solution {
public:
    int numberOfSubstrings(string s) {
        int n=s.length();
        vector<int>freq(3,0);
        int l=0;
        int cnt=0;
        for(int r=0;r<s.length();r++){
            freq[s[r]-'a']++;
            while(freq[0]>0&&freq[1]>0&&freq[2]>0){
                 cnt+=n-r;
                 freq[s[l]-'a']--;
                 l++;
            }
        }
        return cnt;
    }
};
