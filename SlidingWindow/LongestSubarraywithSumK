1----Brute Force
class Solution {
public:
    int longestSubarray(vector<int>& arr, int k) {

        int n = arr.size();
        int maxLength = 0;

        for (int i = 0; i < n; i++) {

            int sum = 0;

            for (int j = i; j < n; j++) {

                sum += arr[j];

                if (sum == k) {
                    maxLength = max(maxLength, j - i + 1);
                }
            }
        }

        return maxLength;
    }
};
2-----Optimsied ocde(prefixSum+hashmap)
class Solution {
  public:
    int longestSubarray(vector<int>& arr, int k) {
        // code here
        unordered_map<int,int>mp;
        // int l=0;
        int sum=0;
        int maxlength=0;
        for(int r=0;r<arr.size();r++){
            sum+=arr[r];
            if(sum==k){
                maxlength=r+1;
            }
            if(mp.find(sum-k)!=mp.end()){
                maxlength=max(maxlength,r-mp[sum-k]);
            }
            if(mp.find(sum)==mp.end()){
                mp[sum]=r;
            }
        }
        return maxlength;
    }
};

"First, I calculate the running prefix sum while traversing the array. If the current prefix sum equals k, then the
subarray starts from index 0. Otherwise, I look for currentSum - k in the HashMap. If it exists, it means I have found a
previous prefix sum, so the subarray between that index and the current index has sum k. I calculate its length and update the maximum length.
Finally, I store the first occurrence of each prefix sum because the earliest occurrence gives the longest possible subarray."
