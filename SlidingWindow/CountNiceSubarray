1. Count exactly K odd numbers.

2. Convert:
   Odd  → 1
   Even → 0

3. Now problem becomes:
   Count Subarrays with Sum = K

4. Use Prefix Sum + HashMap.

5. Only change:
   sum += nums[i] % 2;
class Solution {
public:
    int numberOfSubarrays(vector<int>& nums, int k) {

        unordered_map<int,int> mp;

        mp[0] = 1;

        int sum = 0;
        int count = 0;

        for(int i = 0; i < nums.size(); i++) {

            // Add 1 if odd, otherwise add 0
            sum += nums[i] % 2;

            // Search required prefix sum
            if(mp.find(sum - k) != mp.end()) {
                count += mp[sum - k];
            }

            // Store current prefix sum
            mp[sum]++;
        }

        return count;
    }
};
