1----ADD 1 NUMBER

class Solution {
public:
    ListNode* reverse(ListNode* head){
        ListNode* prev = NULL;
        ListNode* curr = head;
        while(curr){
            ListNode* next = curr->next;
            curr->next = prev;
            prev = curr;
            curr = next;
        }
        return prev;
    }
    ListNode* addOne(ListNode* head) {
        head = reverse(head);

        ListNode* temp = head;
        int carry = 1;

        while(temp != NULL){

            int sum = temp->val + carry;

            temp->val = sum % 10;

            carry = sum / 10;

            if(carry == 0)
                break;

            if(temp->next == NULL){
                temp->next = new ListNode(0);
            }

            temp = temp->next;
        }
        return reverse(head);
    }
};

Interview Explanation
Step 1
"I reverse the linked list because addition starts from the last digit."

Step 2
"I initialize carry as 1 because I need to add one."

Step 3
"I add carry to each node."

Step 4
"If carry becomes zero, I stop."

Step 5
"Finally, I reverse the linked list again."

