class Solution {
public:
    ListNode* reverseList(ListNode* head) {
        ListNode* prev = NULL;
        ListNode* curr = head;
        ListNode* next = NULL;
        while (curr != NULL) {
            next = curr->next;     // Store next node
            curr->next = prev;     // Reverse the link
            prev = curr;           // Move prev forward
            curr = next;           // Move curr forward
        }

        return prev;
    }
};
1. Save next node.

2. Reverse current link.

3. Move prev forward.

4. Move curr forward.

5. Repeat.

6. Return prev.
