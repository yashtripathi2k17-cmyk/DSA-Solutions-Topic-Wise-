class Solution {
public:
    ListNode* reverse(ListNode* head){
        ListNode* prev = NULL;
        ListNode* curr = head;
        while(curr != NULL){
            ListNode* next = curr->next;
            curr->next = prev;
            prev = curr;
            curr = next;
        }
        return prev;
    }
    bool isPalindrome(ListNode* head) {
        if(head == NULL || head->next == NULL)
            return true;
        // Find middle
        ListNode* slow = head;
        ListNode* fast = head;
        while(fast->next != NULL && fast->next->next != NULL){
            slow = slow->next;
            fast = fast->next->next;
        }
        // Reverse second half
        ListNode* second = reverse(slow->next);
        // Compare both halves
        ListNode* first = head;
        while(second != NULL){
            if(first->val != second->val){
                return false;
            }
            first = first->next;
            second = second->next;
        }

        return true;
    }
};

Interview Explanation
Step 1

"First, I find the middle of the linked list using slow and fast pointers."

Step 2

"Then I reverse the second half of the linked list."

Step 3

"Now I compare the first half and the reversed second half node by node."

Step 4

"If any value is different, I return false."

Step 5

"If all values match, the linked list is a palindrome, so I return true."

40-Second Interview Answer

"The brute force solution copies all node values into a vector and checks whether the vector is a palindrome. To optimize it, I first find the middle of the linked list using slow and fast pointers. Then I reverse the second half of the linked list. Finally, I compare the first half and the reversed second half node by node. If all values are equal, I return true; otherwise, I return false."

