class Solution {
public:
    ListNode* middleNode(ListNode* head) {

        ListNode* slow = head;
        ListNode* fast = head;

        while(fast != NULL && fast->next != NULL){

            slow = slow->next;
            fast = fast->next->next;
        }

        return slow;
    }
};
1. Initialize slow and fast at head.

2. Move slow by 1 step.

3. Move fast by 2 steps.

4. Continue until fast reaches the end.

5. Slow will be at the middle.

6. Return slow.
