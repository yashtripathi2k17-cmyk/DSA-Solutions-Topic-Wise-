Balanced Binary Tree (LeetCode 110)
What is a Balanced Binary Tree?
A binary tree is balanced if, for every node:
| Left Height - Right Height | <= 1
That means the difference between the heights of the left and right subtrees should be 0 or 1.
Example 1 (Balanced)
        1
       / \
      2   3
     / \
    4   5

At node 1:

Left Height = 2
Right Height = 1
|2 - 1| = 1 ✓

Every node satisfies the condition.

Answer: True

class Solution {
public:
    int height(TreeNode* root) {

        if (root == NULL)
            return 0;

        int left = height(root->left);
        if (left == -1) return -1;

        int right = height(root->right);
        if (right == -1) return -1;

        if (abs(left - right) > 1)
            return -1;

        return 1 + max(left, right);
    }

    bool isBalanced(TreeNode* root) {
        return height(root) != -1;
    }
};

